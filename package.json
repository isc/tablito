{
  "name": "multiplix-tmp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -b && node scripts/build.mjs",
    "preview": "node scripts/preview.mjs",
    "vendor": "node scripts/vendor-preact.mjs",
    "lint": "eslint .",
    "check-node": "node scripts/check-node.mjs",
    "pretest": "npm run check-node",
    "test": "vitest run",
    "user-guide": "node scripts/generate-user-guide.mjs",
    "mystery-levels": "node scripts/generate-mystery-levels.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "splash": "node scripts/generate-splash.mjs",
    "feedback:list": "node --env-file=.env.local scripts/feedback-list.mjs",
    "feedback:treat": "node --env-file=.env.local scripts/feedback-treat.mjs"
  },
  "dependencies": {
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/cli": "^0.1.9",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.4"
  }
}
